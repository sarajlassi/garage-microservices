# =====================================================
# Environment Configuration - Garage Microservices
# =====================================================
# Copy this file to .env and update with your values

# =====================================================
# Docker Configuration
# =====================================================
DOCKER_REGISTRY=docker.io
DOCKER_USERNAME=your_docker_username
DOCKER_PASSWORD=your_docker_password
DOCKER_EMAIL=your_email@example.com

# =====================================================
# Database Configuration
# =====================================================
DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=localhost

AUTH_DB_NAME=authDB
AUTH_DB_PORT=5432

VEHICLE_DB_NAME=vehicle_db
VEHICLE_DB_PORT=5433

STOCK_DB_NAME=stockDB
STOCK_DB_PORT=5434

# =====================================================
# Kafka Configuration
# =====================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_ZOOKEEPER_CONNECT=localhost:2181

# =====================================================
# JWT Configuration
# =====================================================
JWT_SECRET=404E635266556A586E3272357538782F413F4428472B4B6250645367566B5970
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# =====================================================
# Jenkins Configuration
# =====================================================
JENKINS_URL=http://localhost:8080
JENKINS_USER=admin
JENKINS_PASSWORD=admin
JENKINS_TOKEN=your_jenkins_token

# =====================================================
# SonarQube Configuration
# =====================================================
SONAR_URL=http://localhost:9000
SONAR_LOGIN=admin
SONAR_PASSWORD=admin
SONAR_TOKEN=your_sonarqube_token

# =====================================================
# Kubernetes Configuration
# =====================================================
KUBE_CONTEXT=docker-desktop
KUBE_CONFIG_PATH=~/.kube/config
KUBE_USER=your_kube_user
KUBE_PASS=your_kube_password

# =====================================================
# Email Configuration
# =====================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@garage.local

# =====================================================
# Application Configuration
# =====================================================
ENVIRONMENT=dev
LOG_LEVEL=INFO
TIMEZONE=UTC

# =====================================================
# Image Tags
# =====================================================
IMAGE_TAG_DEV=dev-latest
IMAGE_TAG_STAGING=staging-latest
IMAGE_TAG_PROD=1.0.0

